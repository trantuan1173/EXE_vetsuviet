# ═══════════════════════════════════════════════════════
#  Docker Compose Environment Variables
#  Copy to .env and change values for production
# ═══════════════════════════════════════════════════════

# JWT
JWT_SECRET=vetsuviet_jwt_secret_change_me

# Default admin account (created on first run)
ADMIN_EMAIL=admin@vetsuviet.com
ADMIN_PASSWORD=123456
ADMIN_FULL_NAME=Vết Sử Việt Admin

# App URLs / Docker Hub
CLIENT_URL=http://localhost:3455
DOCKERHUB_USERNAME=your-dockerhub-username

# External MinIO/S3 private video storage (service tách riêng)
# Có thể để trống khi chỉ test local các tính năng không upload video.
S3_ENDPOINT=
S3_PUBLIC_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=vetsuviet-videos
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
VIDEO_PLAYBACK_URL_TTL_SECONDS=600
MAX_VIDEO_SIZE_BYTES=5368709120
